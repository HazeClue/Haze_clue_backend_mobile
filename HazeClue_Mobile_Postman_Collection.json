{
  "info": {
    "name": "HazeClue Mobile API v1",
    "description": "Comprehensive Postman collection for the HazeClue Mobile API (.NET 8 Clean Architecture). Contains all endpoints, detailed request bodies, and expected success examples.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "1. Account & Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"Password123!\",\n  \"phoneNumber\": \"+1234567890\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/account/register", "host": [ "{{baseUrl}}" ], "path": [ "account", "register" ] },
            "description": "Registers a new user and returns a 201 Created with a success message."
          }
        },
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/account/login", "host": [ "{{baseUrl}}" ], "path": [ "account", "login" ] },
            "description": "Authenticates a user and returns a JWT access token, along with basic user details."
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/account/forgot-password", "host": [ "{{baseUrl}}" ], "path": [ "account", "forgot-password" ] }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"otp\": \"123456\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/account/verify-otp", "host": [ "{{baseUrl}}" ], "path": [ "account", "verify-otp" ] }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"otp\": \"123456\",\n  \"newPassword\": \"NewPassword123!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/account/reset-password", "host": [ "{{baseUrl}}" ], "path": [ "account", "reset-password" ] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/account/logout", "host": [ "{{baseUrl}}" ], "path": [ "account", "logout" ] },
            "description": "Revokes the current JWT session."
          }
        },
        {
          "name": "Get Active Sessions",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/account/sessions", "host": [ "{{baseUrl}}" ], "path": [ "account", "sessions" ] },
            "description": "Retrieves all active devices/sessions for the current user."
          }
        },
        {
          "name": "Revoke Session",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/account/sessions/c4b8b8eb-9d18-4b77-8c3b-240e94e5f013", "host": [ "{{baseUrl}}" ], "path": [ "account", "sessions", "c4b8b8eb-9d18-4b77-8c3b-240e94e5f013" ] },
            "description": "Revokes a specific session by its ID."
          }
        },
        {
          "name": "Revoke Other Sessions",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/account/sessions/other", "host": [ "{{baseUrl}}" ], "path": [ "account", "sessions", "other" ] },
            "description": "Revokes all sessions except the one currently making the request."
          }
        },
        {
          "name": "Get Security Logs",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/account/security-logs", "host": [ "{{baseUrl}}" ], "path": [ "account", "security-logs" ] }
          }
        }
      ]
    },
